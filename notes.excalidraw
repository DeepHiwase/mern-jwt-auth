    {
      "id": "qIIpyzTdgIMijKMRt6teE",
      "type": "text",
      "x": 2380.492776308209,
      "y": 1292.7551223637843,
      "width": 885.1636962890625,
      "height": 140,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
